{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "theme": "auto",
  "skillOverrides": {
    "update-config": "off",
    "keybindings-help": "off",
    "simplify": "off",
    "fewer-permission-prompts": "off",
    "loop": "off",
    "schedule": "off",
    "claude-api": "off",
    "init": "off",
    "review": "off",
    "security-review": "off"
  },
  "permissions": {
    "deny": [
      "Skill(update-config)",
      "Skill(keybindings-help)",
      "Skill(simplify)",
      "Skill(fewer-permission-prompts)",
      "Skill(loop)",
      "Skill(schedule)",
      "Skill(claude-api)",
      "Skill(init)",
      "Skill(review)",
      "Skill(security-review)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pre_tool_trigger.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pre_tool_trigger.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pre_tool_trigger.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/post_write_trigger.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/post_write_trigger.py\""
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/post_skill_trigger.py\""
          }
        ]
      }
    ]
  }
}

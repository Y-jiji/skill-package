{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "theme": "auto",
  "skillOverrides": {
    "update-config": "off",
    "keybindings-help": "off",
    "simplify": "off",
    "fewer-permission-prompts": "off",
    "loop": "off",
    "schedule": "off",
    "claude-api": "off",
    "init": "off",
    "review": "off",
    "security-review": "off"
  },
  "permissions": {
    "deny": [
      "Skill(update-config)",
      "Skill(keybindings-help)",
      "Skill(simplify)",
      "Skill(fewer-permission-prompts)",
      "Skill(loop)",
      "Skill(schedule)",
      "Skill(claude-api)",
      "Skill(init)",
      "Skill(review)",
      "Skill(security-review)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/tool_skill.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/tool_write_edit.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/user_prompt_trigger.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/tool_write_edit.py\""
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/tool_skill.py\""
          }
        ]
      }
    ]
  }
}
